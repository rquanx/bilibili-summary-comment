{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ]
}