{
  "name": "video-pipeline",
  "version": "1.0.0",
  "description": "CLI pipeline for downloading videos, transcribing with `vibe`, and summarizing subtitles via either an external command or an OpenAI-compatible `/v1/responses` API.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "pipeline": "node scripts/commands/run-video-pipeline.mjs",
    "test:prompt": "node scripts/maintenance/test-summary-prompt.mjs",
    "login:bili": "node scripts/commands/login-bili-tv.mjs",
    "refresh:cookie": "node scripts/commands/refresh-bili-cookie.mjs",
    "sync:video": "node scripts/commands/sync-bili-video-state.mjs",
    "sync:users": "node scripts/commands/sync-summary-users.mjs",
    "import:summary": "node scripts/commands/import-summary-file.mjs",
    "publish:pending": "node scripts/commands/publish-pending-summaries.mjs",
    "inspect:events": "node scripts/maintenance/inspect-pipeline-events.mjs",
    "cleanup:work": "node scripts/maintenance/cleanup-work-files.mjs",
    "schedule": "node scripts/commands/run-scheduler.mjs",
    "start": "node scripts/commands/run-scheduler.mjs --run-on-start",
    "setup:ps": "powershell -ExecutionPolicy Bypass -File scripts/setup/setup-env.ps1",
    "setup:sh": "bash ./scripts/setup/setup-env.sh",
    "test": "node --test tests/*.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rquanx/video-pipeline.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/rquanx/video-pipeline/issues"
  },
  "homepage": "https://github.com/rquanx/video-pipeline#readme",
  "dependencies": {
    "@renmu/bili-api": "^2.12.5",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "node-cron": "^4.2.1",
    "zod": "^4.3.6"
  }
}
