{
  "name": "video-pipeline",
  "version": "1.0.0",
  "description": "CLI pipeline for downloading videos, transcribing with `vibe`, and summarizing subtitles via either an external command or an OpenAI-compatible `/v1/responses` API.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "node --disable-warning=ExperimentalWarning --import tsx scripts/maintenance/build-dist.ts",
    "dev:api": "node --disable-warning=ExperimentalWarning --import tsx apps/api/src/server.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "pipeline": "node --disable-warning=ExperimentalWarning --import tsx scripts/commands/run-video-pipeline.ts",
    "test:prompt": "node --disable-warning=ExperimentalWarning --import tsx scripts/maintenance/test-summary-prompt.ts",
    "login:bili": "node --disable-warning=ExperimentalWarning --import tsx scripts/commands/login-bili-tv.ts",
    "refresh:cookie": "node --disable-warning=ExperimentalWarning --import tsx scripts/commands/refresh-bili-cookie.ts",
    "sync:video": "node --disable-warning=ExperimentalWarning --import tsx scripts/commands/sync-bili-video-state.ts",
    "sync:users": "node --disable-warning=ExperimentalWarning --import tsx scripts/commands/sync-summary-users.ts",
    "import:summary": "node --disable-warning=ExperimentalWarning --import tsx scripts/commands/import-summary-file.ts",
    "publish:pending": "node --disable-warning=ExperimentalWarning --import tsx scripts/commands/publish-pending-summaries.ts",
    "inspect:events": "node --disable-warning=ExperimentalWarning --import tsx scripts/maintenance/inspect-pipeline-events.ts",
    "cleanup:work": "node --disable-warning=ExperimentalWarning --import tsx scripts/maintenance/cleanup-work-files.ts",
    "schedule": "node --disable-warning=ExperimentalWarning --import tsx scripts/commands/run-scheduler.ts",
    "start": "node --disable-warning=ExperimentalWarning --import tsx scripts/commands/run-scheduler.ts --run-on-start",
    "setup:ps": "powershell -ExecutionPolicy Bypass -File scripts/setup/setup-env.ps1",
    "setup:sh": "bash ./scripts/setup/setup-env.sh",
    "test": "node --disable-warning=ExperimentalWarning --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rquanx/video-pipeline.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/rquanx/video-pipeline/issues"
  },
  "homepage": "https://github.com/rquanx/video-pipeline#readme",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.3.0",
    "@google/genai": "^1.50.1",
    "@renmu/bili-api": "^2.12.5",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-table": "^8.21.3",
    "@types/qrcode-terminal": "^0.12.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "fastify": "^5.6.1",
    "node-cron": "^4.2.1",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.5",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.1.12"
  }
}
